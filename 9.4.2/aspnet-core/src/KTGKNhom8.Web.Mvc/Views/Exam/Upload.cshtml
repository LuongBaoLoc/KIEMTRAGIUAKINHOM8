@{
    ViewBag.Title = "Tải lên Đề thi TOEIC";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0"><i class="fas fa-file-word"></i> TẢI LÊN & BÓC TÁCH ĐỀ THI TOEIC READING</h4>
    </div>
    <div class="card-body">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle"></i> @TempData["ErrorMessage"]
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        }

        <form asp-action="Upload" asp-controller="Exam" method="post" enctype="multipart/form-data">
            <div class="form-group mt-4">
                <label><b>Dữ liệu đầu vào (File Đề Thi .docx) <span class="text-danger">*</span></b></label>
                <div class="custom-file mt-2">
                    <input type="file" class="custom-file-input" id="examFile" name="examFile" accept=".docx" required>
                    <label class="custom-file-label" for="examFile" data-browse="Chọn File">Click để chọn file Word (.docx) - Phải tuân thủ đúng định dạng thẻ Tags</label>
                </div>
            </div>
            
            <hr class="mt-5" />
            <div class="text-right">
                <a href="/" class="btn btn-secondary mr-2"><i class="fas fa-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-cloud-upload-alt"></i> Bắt đầu Tải lên & Xử lý</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Cập nhật tên file lên khung sau khi người dùng chọn file
        $('.custom-file-input').on('change', function() {
            let fileName = $(this).val().split('\\').pop();
            $(this).next('.custom-file-label').addClass("selected").html(fileName);
        });
    </script>
}