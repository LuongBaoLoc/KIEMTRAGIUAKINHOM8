@{
    ViewBag.Title = "Tải lên đề thi TOEIC";
}

<div class="card mt-4">
    <div class="card-header bg-primary text-white">
        <h4><i class="fas fa-upload"></i> TẢI LÊN & BÓC TÁCH ĐỀ THI TOEIC READING</h4>
    </div>
    <div class="card-body">

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }
        
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        <form asp-controller="Exam" asp-action="ProcessUpload" method="post" enctype="multipart/form-data">
            
            <div class="form-group mb-4">
                <label class="font-weight-bold">File Đề Thi (.docx) *</label>
                <div class="custom-file border p-4 text-center rounded bg-light">
                    <i class="fas fa-file-word fa-3x text-primary mb-2"></i><br/>
                <input type="file" name="fileUpload" class="form-control-file d-inline-block w-auto" accept=".docx, .pdf, image/png, image/jpeg" required />                    <p class="text-muted mt-2">Click để chọn file Word (.docx)<br/><small>Phải tuân thủ đúng định dạng thẻ Tags</small></p>
                </div>
            </div>

            <div class="form-group text-right">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-cloud-upload-alt"></i> Bắt đầu Tải lên & Xử lý
                </button>
            </div>
        </form>
    </div>
</div>