@{
    ViewData["Title"] = "Thư viện Đề thi";
}

<style>
    /* Custom CSS cho các thẻ đề thi giống hệt thiết kế */
    .exam-card { border: none; border-radius: 12px; transition: transform 0.2s, box-shadow 0.2s; overflow: hidden; }
    .exam-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    .card-top-blue { background: linear-gradient(135deg, #0d6efd, #0a58ca); color: white; padding: 20px; position: relative;}
    .card-top-green { background: linear-gradient(135deg, #20c997, #198754); color: white; padding: 20px; position: relative;}
    .card-top-purple { background: linear-gradient(135deg, #6f42c1, #59359a); color: white; padding: 20px; position: relative;}
    
    .badge-status { position: absolute; top: 15px; left: 15px; background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); border-radius: 20px; padding: 5px 12px; font-size: 0.75rem; font-weight: bold; letter-spacing: 0.5px;}
    .exam-type { font-size: 0.8rem; color: #6c757d; font-weight: 600; text-transform: uppercase; margin-top: 15px; display: block;}
    .exam-title { font-weight: 700; font-size: 1.1rem; height: 50px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 15px;}
    .exam-stats { font-size: 0.85rem; color: #6c757d; }
    .btn-take-test { font-weight: 600; border-radius: 8px; }
    
    /* Progress bar cho thẻ hoàn thành */
    .score-text { font-size: 1.5rem; font-weight: bold; color: #198754; }
    .progress-custom { height: 6px; border-radius: 3px; background-color: #e9ecef; margin-top: 10px;}
    .progress-bar-custom { height: 100%; border-radius: 3px; background-color: #198754; }
</style>

<div class="container mt-4 mb-5">
    <div class="mb-4">
        <h2 class="fw-bold">Thư viện Đề thi TOEIC Reading</h2>
        <p class="text-muted">Hoàn thành các bài thi dưới đây để cải thiện kỹ năng đọc hiểu của bạn. Chúc bạn đạt kết quả tốt!</p>
    </div>

    <div class="card shadow-sm mb-4 border-0" style="border-radius: 12px;">
        <div class="card-body p-3">
            <div class="row g-2">
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0"><i class="fa-solid fa-magnifying-glass text-muted"></i></span>
                        <input type="text" class="form-control border-start-0 bg-light" placeholder="Tìm kiếm tên đề thi...">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select bg-light text-muted">
                        <option selected>Tất cả trạng thái</option>
                        <option value="1">Mới</option>
                        <option value="2">Đã hoàn thành</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select bg-light text-muted">
                        <option selected>Độ khó: Tất cả</option>
                        <option value="1">Dễ</option>
                        <option value="2">Trung bình</option>
                        <option value="3">Khó</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-md-4">
            <div class="card shadow-sm exam-card h-100">
                <div class="card-top-blue h-50">
                    <span class="badge-status">MỚI</span>
                    <i class="fa-regular fa-file-lines fa-4x text-white opacity-25 position-absolute" style="bottom: -10px; right: 10px;"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <span class="exam-type badge bg-primary bg-opacity-10 text-primary mb-2" style="width: fit-content;">Reading - Part 5,6,7</span>
                    <h5 class="exam-title">TOEIC Reading Actual Test 01 - Trích xuất từ đề thi thật</h5>
                    
                    <div class="row exam-stats mb-4">
                        <div class="col-6 mb-2"><i class="fa-regular fa-clock me-1"></i> 75 Phút</div>
                        <div class="col-6 mb-2"><i class="fa-solid fa-list-ul me-1"></i> 100 Câu</div>
                        <div class="col-6"><i class="fa-solid fa-signal me-1"></i> Trung bình</div>
                        <div class="col-6"><i class="fa-solid fa-users me-1"></i> 1.2k Lượt làm</div>
                    </div>
                    
                    <div class="mt-auto">
                        <a asp-controller="Exam" asp-action="TakeTest" class="btn btn-primary w-100 btn-take-test"><i class="fa-solid fa-play me-2"></i> Bắt đầu làm bài</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm exam-card h-100">
                <div class="card-top-green h-50">
                    <span class="badge-status"><i class="fa-solid fa-check me-1"></i> ĐÃ HOÀN THÀNH</span>
                    <i class="fa-solid fa-gear fa-4x text-white opacity-25 position-absolute" style="bottom: -10px; right: 10px;"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <span class="exam-type badge bg-success bg-opacity-10 text-success mb-2" style="width: fit-content;">Reading Practice</span>
                    <h5 class="exam-title">TOEIC Reading Test 02 - Hacker ETS 2023 Format</h5>
                    
                    <div class="mb-3">
                        <span class="d-block text-muted" style="font-size: 0.8rem; font-weight: 600;">KẾT QUẢ BÀI LÀM GẦN NHẤT</span>
                        <div class="d-flex align-items-baseline">
                            <span class="score-text">85</span><span class="text-muted ms-1" style="font-size: 0.9rem;">/ 100 câu đúng</span>
                        </div>
                        <div class="progress-custom">
                            <div class="progress-bar-custom" style="width: 85%;"></div>
                        </div>
                    </div>
                    
                    <div class="mt-auto row g-2">
                        <div class="col-6">
                            <a href="#" class="btn btn-outline-success w-100 btn-take-test"><i class="fa-solid fa-chart-simple me-1"></i> Chi tiết</a>
                        </div>
                        <div class="col-6">
                            <a href="#" class="btn btn-dark w-100 btn-take-test"><i class="fa-solid fa-rotate-right me-1"></i> Thi lại</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm exam-card h-100">
                <div class="card-top-purple h-50">
                    <span class="badge-status">MỚI</span>
                    <i class="fa-solid fa-bolt fa-4x text-white opacity-25 position-absolute" style="bottom: -10px; right: 10px;"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <span class="exam-type badge" style="background-color: #f3e8ff; color: #6f42c1; width: fit-content; margin-bottom: 8px;">Mini Test</span>
                    <h5 class="exam-title">Ngữ pháp chuyên sâu: Incomplete Sentences (Part 5)</h5>
                    
                    <div class="row exam-stats mb-4">
                        <div class="col-6 mb-2"><i class="fa-regular fa-clock me-1"></i> 15 Phút</div>
                        <div class="col-6 mb-2"><i class="fa-solid fa-list-ul me-1"></i> 30 Câu</div>
                    </div>
                    
                    <div class="mt-auto">
                        <a href="#" class="btn w-100 btn-take-test text-white" style="background-color: #6f42c1;"><i class="fa-solid fa-play me-2"></i> Bắt đầu làm bài</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>