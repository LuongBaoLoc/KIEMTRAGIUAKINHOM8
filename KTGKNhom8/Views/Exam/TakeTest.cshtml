@{
    ViewData["Title"] = "Làm bài thi";
    int timeInMinutes = ViewBag.TimeInMinutes ?? 75;
}

<style>
    /* CSS Tùy chỉnh cho giao diện làm bài */
    .question-box { background: #fff; border-radius: 8px; border: 1px solid #e0e0e0; margin-bottom: 20px; padding: 20px; }
    .answer-option { display: block; padding: 10px 15px; margin-bottom: 10px; border: 1px solid #ced4da; border-radius: 6px; cursor: pointer; transition: all 0.2s; }
    .answer-option:hover { background: #f8f9fa; border-color: #0d6efd; }
    /* Ẩn radio button mặc định, chỉ dùng UI của label */
    .answer-option input[type="radio"] { display: none; }
    .answer-option input[type="radio"]:checked + span { font-weight: bold; color: #0d6efd; }
    .answer-option:has(input[type="radio"]:checked) { border-color: #0d6efd; background-color: #e9ecef; box-shadow: 0 0 0 1px #0d6efd; }
    
    /* Panel bên phải (Đồng hồ & Phiếu trả lời) */
    .right-panel { position: sticky; top: 20px; }
    .timer-box { background: #1a233a; color: #00ff88; font-size: 2.5rem; font-weight: bold; text-align: center; border-radius: 8px; padding: 15px; margin-bottom: 20px; font-family: monospace;}
    
    .answer-sheet { background: #fff; border-radius: 8px; border: 1px solid #e0e0e0; padding: 15px; max-height: 500px; overflow-y: auto; }
    .sheet-btn { width: 40px; height: 40px; text-align: center; padding: 0; line-height: 40px; border-radius: 4px; border: 1px solid #ced4da; background: #fff; margin: 3px; font-weight: 500; font-size: 0.9rem;}
    .sheet-btn.answered { background: #0d6efd; color: #fff; border-color: #0d6efd; }
</style>

<div class="row mt-3">
    <div class="col-lg-8">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="text-primary fw-bold mb-0"><i class="fa-solid fa-file-pen"></i> @ViewBag.ExamTitle</h4>
            <span class="badge bg-secondary fs-6">Part 5: Incomplete Sentences</span>
        </div>

        <div class="question-box" id="q101">
            <h5 class="text-primary"><i class="fa-solid fa-bookmark"></i> Câu 101</h5>
            <p class="fs-5 mt-3">Ms. Durkin asked for volunteers to help _______ with the employee fitness program.</p>
            <div class="row mt-3">
                <div class="col-md-6">
                    <label class="answer-option" onclick="markAnswered(101)">
                        <input type="radio" name="q101" value="A"> <span><b>A.</b> she</span>
                    </label>
                    <label class="answer-option" onclick="markAnswered(101)">
                        <input type="radio" name="q101" value="B"> <span><b>B.</b> her</span>
                    </label>
                </div>
                <div class="col-md-6">
                    <label class="answer-option" onclick="markAnswered(101)">
                        <input type="radio" name="q101" value="C"> <span><b>C.</b> hers</span>
                    </label>
                    <label class="answer-option" onclick="markAnswered(101)">
                        <input type="radio" name="q101" value="D"> <span><b>D.</b> herself</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="question-box" id="q102">
            <h5 class="text-primary"><i class="fa-solid fa-bookmark"></i> Câu 102</h5>
            <p class="fs-5 mt-3">What is true about Lasner Electronics' staff?</p>
            <div class="row mt-3">
                <div class="col-md-6">
                    <label class="answer-option" onclick="markAnswered(102)">
                        <input type="radio" name="q102" value="A"> <span><b>A.</b> They have extensive knowledge.</span>
                    </label>
                    <label class="answer-option" onclick="markAnswered(102)">
                        <input type="radio" name="q102" value="B"> <span><b>B.</b> They work overtime.</span>
                    </label>
                </div>
                <div class="col-md-6">
                    <label class="answer-option" onclick="markAnswered(102)">
                        <input type="radio" name="q102" value="C"> <span><b>C.</b> They are new employees.</span>
                    </label>
                    <label class="answer-option" onclick="markAnswered(102)">
                        <input type="radio" name="q102" value="D"> <span><b>D.</b> All of the above are correct.</span>
                    </label>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="right-panel">
            <div class="timer-box shadow-sm">
                <i class="fa-regular fa-clock fs-4"></i> <span id="countdown">--:--</span>
            </div>

            <div class="answer-sheet shadow-sm">
                <h6 class="fw-bold mb-3 border-bottom pb-2"><i class="fa-solid fa-table-cells"></i> Phiếu trả lời</h6>
                <div class="d-flex flex-wrap">
                    <a href="#q101" class="btn sheet-btn" id="btn-sheet-101">101</a>
                    <a href="#q102" class="btn sheet-btn" id="btn-sheet-102">102</a>
                    <a href="#" class="btn sheet-btn">103</a>
                    <a href="#" class="btn sheet-btn">104</a>
                    <a href="#" class="btn sheet-btn">105</a>
                </div>
            </div>

            <button class="btn btn-dark w-100 mt-3 py-2 fw-bold fs-5 shadow"><i class="fa-solid fa-flag-checkered"></i> NỘP BÀI THI</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Chức năng đổi màu ô bên phải khi đã chọn đáp án
        function markAnswered(questionId) {
            document.getElementById('btn-sheet-' + questionId).classList.add('answered');
        }

        // 2. Chức năng Đồng hồ đếm ngược
        let timeInMinutes = @timeInMinutes;
        let timeInSeconds = timeInMinutes * 60;
        let display = document.getElementById('countdown');

        function startTimer() {
            let timer = setInterval(function () {
                let minutes = parseInt(timeInSeconds / 60, 10);
                let seconds = parseInt(timeInSeconds % 60, 10);

                minutes = minutes < 10 ? "0" + minutes : minutes;
                seconds = seconds < 10 ? "0" + seconds : seconds;

                display.textContent = minutes + ":" + seconds;

                // Cảnh báo khi còn dưới 5 phút (đổi sang màu đỏ)
                if(timeInSeconds < 300) {
                    document.querySelector('.timer-box').style.color = '#ff4d4d';
                }

                if (--timeInSeconds < 0) {
                    clearInterval(timer);
                    display.textContent = "00:00";
                    alert("Đã hết thời gian làm bài!");
                    // TODO: Tự động submit form nộp bài tại đây
                }
            }, 1000);
        }

        // Chạy đồng hồ khi trang load xong
        window.onload = function () {
            startTimer();
        };
    </script>
}